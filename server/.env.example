PORT=3000
CLIENT_ORIGIN=http://localhost:4200
PUBLIC_SITE_ORIGIN=http://localhost:3000
# SITE_DOMAIN: base domain for subdomain-style business site hosting.
# Each saved site is served at businessname.SITE_DOMAIN
# Default: localhost → businessname.localhost:3000 (works in Chrome/Firefox/Safari, no DNS setup needed)
# Self-hosted:        → businessname.yourdomain.com  (requires wildcard DNS: *.yourdomain.com → your server IP)
SITE_DOMAIN=localhost
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
DATABASE_URL=sqlite:data/pixora.sqlite
GOOGLE_CLIENT_ID=
ADMIN_EMAILS=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:4200?checkout=success&session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:4200?checkout=cancel
DOMAIN_SUCCESS_URL=http://localhost:4200?domain_checkout=success&session_id={CHECKOUT_SESSION_ID}
DOMAIN_CANCEL_URL=http://localhost:4200?domain_checkout=cancel
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

